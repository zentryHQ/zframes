{
  "name": "@zframes/providers-keyless",
  "version": "0.0.0",
  "description": "The keyless zframes market-data provider set as a single composition factory — imports the 15 free, no-key provider packages and returns them in capability-routing order. Shared by every app that mounts the runtime (apps/runtime, apps/explorer) so the keyless set lives in one place instead of a duplicated per-app list.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/providers-keyless"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zframes/provider-alternativeme": "workspace:*",
    "@zframes/provider-bls": "workspace:*",
    "@zframes/provider-coingecko": "workspace:*",
    "@zframes/provider-coinpaprika": "workspace:*",
    "@zframes/provider-defillama": "workspace:*",
    "@zframes/provider-deribit": "workspace:*",
    "@zframes/provider-finra": "workspace:*",
    "@zframes/provider-fx": "workspace:*",
    "@zframes/provider-hyperliquid": "workspace:*",
    "@zframes/provider-mempool": "workspace:*",
    "@zframes/provider-news": "workspace:*",
    "@zframes/provider-nyfed": "workspace:*",
    "@zframes/provider-ofr": "workspace:*",
    "@zframes/provider-sec": "workspace:*",
    "@zframes/provider-treasury": "workspace:*",
    "@zframes/spec": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
