{
  "name": "@zframes/frames",
  "version": "0.0.0",
  "description": "Built-in zframes frames (price-chart, ticker, top-movers, funding chart/heatmap, TVL treemap, sentiment, and more) plus their AI-facing Zod schemas.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/frames"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
