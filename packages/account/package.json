  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/account"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./account": "./src/account.ts"
  },
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zframes/spec": "workspace:*",
    "@zframes/store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.8.0"
  }
