{
  "name": "@zframes/vite",
  "version": "0.0.0",
  "description": "zframes dev Vite plugin (Node-only): dashboardWriteback() composes the serve/proxy, zAI, and account handlers and serves the global-default dashboard for the app to fetch.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/vite"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts"
  },
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zframes/account": "workspace:*",
    "@zframes/serve": "workspace:*",
    "@zframes/store": "workspace:*",
    "@zframes/zai": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.0"
  }
}
