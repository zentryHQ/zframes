{
  "name": "zframes",
  "version": "0.1.0",
  "description": "zframes CLI — scaffold a runnable dashboard app (init), print the frame catalogue for generating agents (catalogue), and validate a dashboard.json (lint).",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentry/zframes.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/zentry/zframes#readme",
  "keywords": [
    "zframes",
    "dashboard",
    "market",
    "trading",
    "cli",
    "ai",
    "agent",
    "hyperliquid"
  ],
  "type": "module",
  "bin": {
    "zframes": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "node scripts/sync-template.mjs && tsup",
    "prepack": "node scripts/sync-template.mjs && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@zframes/core": "workspace:*",
    "@zframes/frames": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0"
  }
}
