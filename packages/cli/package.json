{
  "name": "zframes",
  "version": "0.5.0",
  "description": "zframes CLI \u2014 serve a dashboard.json as a live, editable market terminal (serve), print the frame catalogue for generating agents (catalogue), and validate a dashboard.json (lint).",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/zentryhq/zframes#readme",
  "keywords": [
    "zframes",
    "dashboard",
    "market",
    "trading",
    "cli",
    "ai",
    "agent",
    "hyperliquid"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "zframes": "dist/index.js"
  },
  "files": [
    "dist",
    "runtime",
    "NOTICE"
  ],
  "scripts": {
    "build": "node scripts/build-runtime.mjs && tsup && node scripts/assert-artifacts.mjs",
    "prepack": "node scripts/build-runtime.mjs && tsup && node scripts/assert-artifacts.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "sirv": "^3.0.2",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@zframes/account": "workspace:*",
    "@zframes/frames": "workspace:*",
    "@zframes/provider-alternativeme": "workspace:*",
    "@zframes/provider-coingecko": "workspace:*",
    "@zframes/provider-defillama": "workspace:*",
    "@zframes/provider-hyperliquid": "workspace:*",
    "@zframes/serve": "workspace:*",
    "@zframes/spec": "workspace:*",
    "@zframes/store": "workspace:*",
    "@zframes/zai": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0"
  }
}
