{
  "name": "@zframes/core",
  "version": "0.0.0",
  "description": "Core runtime for zframes: frame/registry primitives, the dashboard spec schema, the renderer, capability-routed provider hooks, and the AI catalogue.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/core"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./frame": "./src/frame.ts",
    "./spec": "./src/spec.ts",
    "./catalogue": "./src/catalogue.ts",
    "./fetch": "./src/fetch.ts",
    "./editor": "./src/editor.tsx",
    "./vite": "./src/vite.ts",
    "./serve": "./src/serve.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gridstack": "^12.1.0",
    "zod": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0"
  }
}
