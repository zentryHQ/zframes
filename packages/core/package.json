{
  "name": "@zframes/core",
  "version": "0.0.0",
  "description": "Core runtime for zframes: frame/registry primitives, the dashboard spec schema, the renderer, capability-routed provider hooks, and the AI catalogue.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/core"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./frame": "./src/facade/frame.ts",
    "./spec": "./src/facade/spec.ts",
    "./catalogue": "./src/facade/catalogue.ts",
    "./routes": "./src/facade/routes.ts",
    "./fetch": "./src/fetch.ts",
    "./cache": "./src/cache.ts",
    "./editor": "./src/editor.tsx",
    "./editor-symbols": "./src/editor-symbols.ts",
    "./vite": "./src/vite.ts",
    "./serve": "./src/serve.ts",
    "./store": "./src/store.ts",
    "./agent": "./src/agent.ts",
    "./account": "./src/account.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zframes/spec": "workspace:*",
    "gridstack": "^12.1.0",
    "lucide-react": "^1.21.0",
    "zod": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0"
  }
}
