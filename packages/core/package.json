{
  "name": "@zframes/core",
  "version": "0.0.0",
  "description": "zframes presentation layer: DashboardRenderer, the shared frame chrome (FrameContent/FRAME_CSS), capability-routed provider hooks, and visibility gating. Re-exports the @zframes/spec kernel, so the root barrel stays the stable public surface.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/core"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zframes/spec": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "zod": "^4.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0"
  }
}
