{
  "name": "@zframes/core",
  "version": "0.0.0",
  "description": "Core runtime for zframes: frame/registry primitives, the dashboard spec schema, the renderer, capability-routed provider hooks, and the AI catalogue.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git",
    "directory": "packages/core"
  },
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./frame": "./src/facade/frame.ts",
    "./spec": "./src/facade/spec.ts",
    "./catalogue": "./src/facade/catalogue.ts",
    "./routes": "./src/facade/routes.ts",
    "./fetch": "./src/facade/fetch.ts",
    "./cache": "./src/facade/cache.ts",
    "./editor": "./src/facade/editor.ts",
    "./editor-symbols": "./src/facade/editor-symbols.ts",
    "./vite": "./src/facade/vite.ts",
    "./serve": "./src/facade/serve.ts",
    "./store": "./src/facade/store.ts",
    "./agent": "./src/facade/agent.ts",
    "./account": "./src/facade/account.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zframes/account": "workspace:*",
    "@zframes/data-primitives": "workspace:*",
    "@zframes/serve": "workspace:*",
    "@zframes/spec": "workspace:*",
    "@zframes/editor": "workspace:*",
    "@zframes/store": "workspace:*",
    "@zframes/vite": "workspace:*",
    "@zframes/zai": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "zod": "^4.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0"
  }
}
