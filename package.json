{
  "name": "zframes-monorepo",
  "description": "AI-personalizable market dashboard framework — an agent reads the frame catalogue, emits a dashboard.json spec, and the runtime validates and renders it as a live dashboard.",
  "license": "Apache-2.0",
  "author": "Zentry",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentryhq/zframes.git"
  },
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "scripts": {
    "dev": "pnpm --filter @zframes/runtime dev",
    "build": "pnpm --filter @zframes/runtime build",
    "typecheck": "pnpm -r typecheck",
    "zframes": "node packages/cli/dist/index.js",
    "build:cli": "pnpm --filter zframes build",
    "format": "pnpm dlx prettier@3 --write .",
    "format:check": "pnpm dlx prettier@3 --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:providers": "tsx .github/scripts/provider-smoke.ts",
    "test:frames:render": "tsx .github/scripts/frame-render-smoke.ts"
  },
  "pnpm": {
    "patchedDependencies": {
      "liveline@0.0.7": "patches/liveline@0.0.7.patch"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@zframes/provider-sec": "workspace:^",
    "@zframes/providers-keyless": "workspace:^",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.53.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
