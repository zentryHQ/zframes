node_modules/
dist/
.vite/
*.log
*.tgz
.DS_Store
.env
.env.*

# Internal Claude Design-sync tooling — local-only, never in the public repo.
.ds-sync/
ds-bundle/
.design-sync/
packages/catalogue/

# Derived: the prebuilt browser runtime vendored into the CLI by build:cli
# (a vite build of apps/runtime that `zframes serve` ships)
packages/cli/runtime/

# Local dev dogfood data — `pnpm dev` reads/writes these (the dashboard spec is
# the in-browser editor's Save target; the analysis log is what /zframes-brief
# writes), but they're local working files, not published artifacts. The shipped
# CLI never uses them. Create your own to run dev (e.g.
# `zframes init apps/runtime/src/dashboard.json`); the brief frame degrades to an
# empty "no brief yet" state when its log is absent.
apps/runtime/src/dashboard.json
apps/runtime/public/daily-analysis.json

# Local-only docs — kept on disk, never committed to the public repo.
# Everything under docs/ is local working material (the six-slot taxonomy:
# central-plan/, decisions/, specs/, reference/, artifacts/, archive/) EXCEPT
# docs/assets/ (README images), which stays tracked.
docs/*
!docs/assets/

# Local-only scratch & promo tooling (root-level only) — Python generators and
# their large generated JSON outputs (theme variants, gap-test fixtures). Local
# working files, not project source, never committed to the public repo. The
# leading slash anchors to the repo root so the CLI's own packages/cli/scripts/
# stays tracked.
/scripts/
/promo/

# Python bytecode — should never be committed anywhere in this JS/TS repo.
__pycache__/
*.pyc
.claude/

# scheduled-monitor generated reports (.github/scripts)
provider-smoke-report.json
cli-smoke-report.json
audit-report.json
frame-render-report.json
